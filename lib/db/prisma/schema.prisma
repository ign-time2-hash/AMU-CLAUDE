generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  planejador
  cliente
  tecnico_externo
}

enum Cenpes {
  cenpes_1
  cenpes_2
}

enum Prioridade {
  baixa
  normal
  alta
}

enum ChamadoStatus {
  em_espera
  em_progresso
  concluido
  recusado
}

enum Criticidade {
  baixa
  normal
  alta
}

enum RescheduleStatus {
  pendente
  aprovado
  recusado
}

model User {
  username     String   @id
  passwordHash String   @map("password_hash")
  name         String
  jobTitle     String   @default("") @map("job_title")
  role         UserRole
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("users")
}

model Setor {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  cenpes    Cenpes  @default(cenpes_2)
  mapX      Float?  @map("map_x")
  mapY      Float?  @map("map_y")
  labs      Lab[]

  @@map("setores")
}

model Lab {
  id                 Int                @id @default(autoincrement())
  name               String             @unique
  location           String             @default("")
  idSetor            Int?               @map("id_setor")
  setor              Setor?             @relation(fields: [idSetor], references: [id], onDelete: SetNull)
  equipamentos       Equipamento[]
  chamados           Chamado[]
  webhooks           Webhook[]
  rescheduleRequests RescheduleRequest[]

  @@map("labs")
}

model Equipamento {
  id                Int         @id @default(autoincrement())
  name              String
  idLab             Int         @map("id_lab")
  lab               Lab         @relation(fields: [idLab], references: [id], onDelete: Cascade)
  localInstalacao   String?     @map("local_instalacao") @db.VarChar(120)
  gerencia          String?     @db.VarChar(120)
  criticidade       Criticidade @default(normal)
  createdByUsername String?     @map("created_by_username")
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([name, idLab])
  @@map("equipamentos")
}

model Chamado {
  id               Int           @id @default(autoincrement())
  labId            Int           @map("lab_id")
  lab              Lab           @relation(fields: [labId], references: [id])
  openedBy         String        @map("opened_by")
  machineName      String        @map("machine_name")
  description      String
  priority         Prioridade    @default(normal)
  status           ChamadoStatus @default(em_espera)
  rejectionReason  String?       @map("rejection_reason")
  assignedToUsername String?     @map("assigned_to_username")
  comments         ChamadoComment[]
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("chamados")
}

model ChamadoComment {
  id            Int      @id @default(autoincrement())
  chamadoId     Int      @map("chamado_id")
  chamado       Chamado  @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  authorUsername String  @map("author_username")
  authorName    String   @map("author_name")
  body          String
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("chamado_comments")
}

model RescheduleRequest {
  id                 Int              @id @default(autoincrement())
  eventId            String           @map("event_id")
  calendarId         String           @map("calendar_id")
  labId              Int?             @map("lab_id")
  lab                Lab?             @relation(fields: [labId], references: [id])
  requestedByName    String           @map("requested_by_name")
  reason             String
  suggestedStart     DateTime?        @map("suggested_start") @db.Timestamptz(6)
  suggestedEnd       DateTime?        @map("suggested_end") @db.Timestamptz(6)
  status             RescheduleStatus @default(pendente)
  decisionReason     String?          @map("decision_reason")
  newStart           DateTime?        @map("new_start") @db.Timestamptz(6)
  newEnd             DateTime?        @map("new_end") @db.Timestamptz(6)
  decidedByUsername  String?          @map("decided_by_username")
  decidedAt          DateTime?        @map("decided_at") @db.Timestamptz(6)
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("reschedule_requests")
}

model Webhook {
  id         Int      @id @default(autoincrement())
  name       String
  url        String
  labId      Int?     @map("lab_id")
  lab        Lab?     @relation(fields: [labId], references: [id])
  enabled    Boolean  @default(true)
  lastSentAt DateTime? @map("last_sent_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("webhooks")
}
